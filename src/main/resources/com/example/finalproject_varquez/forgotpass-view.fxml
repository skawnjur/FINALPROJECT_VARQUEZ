<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" styleClass="root-pane" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.finalproject_varquez.forgotPasswordController">

    <VBox alignment="CENTER" maxWidth="320" spacing="0" styleClass="login-card" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="140.0" AnchorPane.rightAnchor="140.0" AnchorPane.topAnchor="20.0">
        <padding>
            <Insets bottom="24" left="24" right="24" top="24" />
        </padding>

        <StackPane styleClass="logo-badge">
            <Label styleClass="logo-icon" text="💳" />
        </StackPane>

        <Label styleClass="title-text" text="  Reset password">
            <VBox.margin>
                <Insets bottom="4" top="12" />
            </VBox.margin>
        </Label>
        <Label styleClass="subtitle-text" text="Enter your account details">
            <VBox.margin>
                <Insets bottom="20" />
            </VBox.margin>
        </Label>

        <VBox spacing="6" styleClass="field-group">
            <Label styleClass="field-label" text="Mobile number or email" />
            <TextField fx:id="usernameField" promptText="09XX XXX XXXX" styleClass="text-input" />
        </VBox>

        <VBox spacing="6" styleClass="field-group">
            <VBox.margin>
                <Insets top="12" />
            </VBox.margin>
            <Label styleClass="field-label" text="New password" />
            <PasswordField fx:id="newPasswordField" promptText="Enter new password" styleClass="text-input" />
        </VBox>

        <VBox spacing="6" styleClass="field-group">
            <VBox.margin>
                <Insets top="12" />
            </VBox.margin>
            <Label styleClass="field-label" text="Confirm new password" />
            <PasswordField fx:id="confirmPasswordField" promptText="Re-enter new password" styleClass="text-input" />
        </VBox>

        <Button fx:id="resetButton" maxWidth="Infinity" onAction="#handleResetPassword" styleClass="btn-primary" text="Reset password">
            <VBox.margin>
                <Insets bottom="14" top="20" />
            </VBox.margin>
        </Button>

        <HBox alignment="CENTER" spacing="4">
            <Label styleClass="text-secondary" text="Remembered your password?" />
            <Hyperlink fx:id="backToLoginLink" onAction="#handleBackToLogin" styleClass="link-text" text="Log in" />
        </HBox>

    </VBox>

</AnchorPane>